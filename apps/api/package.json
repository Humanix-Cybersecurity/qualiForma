{
  "name": "@humanix/api",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:isolation": "jest --config test/jest-isolation.json --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:rls": "node scripts/apply-rls.mjs",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "pnpm prisma:migrate && pnpm db:rls && pnpm db:seed"
  },
  "dependencies": {
    "@humanix/domain": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "helmet": "^8.0.0",
    "nestjs-pino": "^4.1.0",
    "otplib": "^12.0.1",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "pg": "^8.13.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  }
}
