{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "moduleNameMapper": {
    "^@humanix/domain$": "<rootDir>/../../packages/domain/src/index.ts"
  },
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "testTimeout": 30000
}
