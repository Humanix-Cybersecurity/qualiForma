# SPDX-License-Identifier: AGPL-3.0-or-later
# Copier vers .env (jamais commité). Aucun secret en clair dans le dépôt.

# --- API ---
NODE_ENV=development
API_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- PostgreSQL (RLS multi-tenant) ---
# Runtime applicatif : rôle `app` NON superuser et NON BYPASSRLS (la RLS s'applique).
DATABASE_URL=postgresql://app:app@localhost:5432/humanix?schema=public
# Migrations / DDL : rôle propriétaire (superuser). Utilisé UNIQUEMENT par prisma migrate + db:rls.
DATABASE_MIGRATION_URL=postgresql://humanix_admin:humanix_admin@localhost:5432/humanix?schema=public

# Clé de chiffrement applicatif (secrets MFA au repos). 32 octets en base64. NE PAS réutiliser en prod.
APP_ENCRYPTION_KEY=ZGV2LW9ubHktMzItYnl0ZS1rZXktY2hhbmdlLW1lISE=

# --- Auth ---
JWT_ACCESS_SECRET=change-me-dev-only
JWT_REFRESH_SECRET=change-me-dev-only
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
MFA_ISSUER=Humanix

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Stockage objet S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-1
S3_BUCKET=humanix
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_SSE=true

# --- ClamAV ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Horodatage (RFC 3161 / eIDAS) — optionnel, sinon horodatage serveur NTP ---
TSA_URL=
TSA_ENABLED=false

# --- Conservation / RGPD ---
PREUVE_RETENTION_YEARS=4
